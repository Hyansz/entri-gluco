---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

import lancing from "../assets/lancing.png";
import lancet from "../assets/lanced.png";
import gluco from "../assets/alat-gluco-n3.png";
import strip from "../assets/strip.png";
import guide from "../assets/guide-book.png";
---

<section
    class="py-24 mx-auto max-w-[2000px] bg-linear-to-t from-[#095CB5] to-[#078AD0] poppins"
>
    <div class="max-w-7xl mx-auto px-6">
        <h2
            class="text-3xl font-bold text-center mb-36 md:mb-16 bg-[#FD6101] w-fit mx-auto px-8 py-3 text-white rounded-2xl"
        >
            Bundle
        </h2>
        <div
            class="grid grid-cols-2 md:grid-cols-5 gap-x-6 gap-y-20 md:gap-6 pt-20 md:pt-36 max-w-6xl mx-auto"
        >
            <!-- CARD -->
            <div
                class="relative hover:-translate-y-1 transition duration-300 mb-20 md:mb-0"
            >
                <Image
                    src={lancing}
                    alt="Lancing Device"
                    width={80}
                    class="absolute w-10 left-1/2 bottom-20 -translate-x-1/2 drop-shadow-[0_25px_35px_rgba(0,0,0,0.25)]"
                />
                <div
                    class="bg-[#EDEDED] rounded-3xl h-[180px] pt-24 pb-6 px-4 text-center shadow-[0_15px_35px_rgba(0,0,0,0.18)] flex items-end justify-center"
                >
                    <p class="font-semibold text-gray-800">Lancing Device</p>
                </div>
            </div>
            <!-- CARD -->
            <div
                class="relative hover:-translate-y-1 transition duration-300 mb-20 md:mb-0"
            >
                <Image
                    src={lancet}
                    alt="Blood Lancet"
                    width={170}
                    class="absolute w-40 left-1/2 bottom-20 -translate-x-1/2 drop-shadow-[0_25px_35px_rgba(0,0,0,0.25)]"
                />
                <div
                    class="bg-[#EDEDED] rounded-3xl h-[180px] pt-24 pb-6 px-4 text-center shadow-[0_15px_35px_rgba(0,0,0,0.18)] flex items-end justify-center"
                >
                    <p class="font-semibold text-gray-800">
                        50 Pcs<br />Blood Lancet
                    </p>
                </div>
            </div>
            <!-- CARD -->
            <div
                class="relative hover:-translate-y-1 transition duration-300 mb-20 md:mb-0"
            >
                <Image
                    src={gluco}
                    alt="N3 Gluco Meter"
                    width={170}
                    class="absolute w-40 left-1/2 bottom-14 -translate-x-1/2 drop-shadow-[0_25px_35px_rgba(0,0,0,0.25)]"
                />
                <div
                    class="bg-[#EDEDED] rounded-3xl h-[180px] pt-24 pb-6 px-4 text-center shadow-[0_15px_35px_rgba(0,0,0,0.18)] flex items-end justify-center"
                >
                    <p class="font-semibold text-gray-800">N3 Gluco Meter</p>
                </div>
            </div>
            <!-- CARD -->
            <div
                class="relative hover:-translate-y-1 transition duration-300 mb-20 md:mb-0"
            >
                <Image
                    src={strip}
                    alt="N3 Gluco Strip"
                    width={170}
                    class="absolute w-36 left-1/2 bottom-20 -translate-x-1/2 drop-shadow-[0_25px_35px_rgba(0,0,0,0.25)]"
                />
                <div
                    class="bg-[#EDEDED] rounded-3xl h-[180px] pt-24 pb-6 px-4 text-center shadow-[0_15px_35px_rgba(0,0,0,0.18)] flex items-end justify-center"
                >
                    <p class="font-semibold text-gray-800">
                        50 Pcs<br />N3 Gluco Strip
                    </p>
                </div>
            </div>
            <!-- CARD -->
            <div
                class="relative hover:-translate-y-1 transition duration-300"
            >
                <Image
                    src={guide}
                    alt="Buku Panduan"
                    width={170}
                    class="absolute w-40 left-1/2 bottom-20 -translate-x-1/2 drop-shadow-[0_25px_35px_rgba(0,0,0,0.25)]"
                />
                <div
                    class="bg-[#EDEDED] rounded-3xl h-[180px] pt-24 pb-6 px-4 text-center shadow-[0_15px_35px_rgba(0,0,0,0.18)] flex items-end justify-center"
                >
                    <p class="font-semibold text-gray-800">Buku Panduan</p>
                </div>
            </div>
        </div>
    </div>

    <!-- buat disini -->
    <div class="mt-20 flex justify-center px-6">
        <div
            class="bg-white rounded-2xl shadow-xl px-8 py-5 flex items-start md:items-center gap-6 md:gap-10 max-w-4xl w-full flex-col md:flex-row justify-between"
        >
            <div class="flex items-center gap-3 text-[#0A4EA3] font-semibold">
                <Icon name="heroicons:shield-check" class="size-11" />
                <span>Alat Bergaransi Seumur Hidup</span>
            </div>

            <div class="h-px w-[90%] md:h-8 md:w-px bg-gray-300"></div>

            <div class="flex items-center gap-3 text-[#0A4EA3] font-semibold">
                <Icon name="heroicons:bolt" class="size-10" />
                <span>Hasil Cepat dan Akurat</span>
            </div>

            <div class="h-px w-[90%] md:h-8 md:w-px bg-gray-300"></div>

            <div class="flex items-center gap-3 text-[#0A4EA3] font-semibold">
                <Icon name="heroicons:cpu-chip" class="size-13" />
                <span>Memori Hingga 1000 Data Pemakaian</span>
            </div>
        </div>
    </div>
</section>
